# Database — PostgreSQL (local: docker compose up -d)
DATABASE_URL="postgresql://tripsync:tripsync@localhost:5432/tripsync"

# Vercel / Neon: cole a connection string postgresql://...

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET="change-me-in-production"
AUTH_URL="http://localhost:3000"

# TripSync API — when set, Platform calls the API for bookings.
# Keep empty to use the local Prisma fallback during standalone development.
# TRIPSYNC_API_URL="http://localhost:3333"
# TRIPSYNC_API_TOKEN=""

# Optional GitHub OAuth
# AUTH_GITHUB_ID=""
# AUTH_GITHUB_SECRET=""
